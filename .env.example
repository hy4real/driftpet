# Shared app config
TELEGRAM_BOT_TOKEN=
# Optional Obsidian vault root for note workflows.
# Defaults to /Users/mac/my-obsidian-vault when unset.
# DRIFTPET_VAULT_DIR=/Users/mac/my-obsidian-vault
# Optional command overrides for note workflows and Claude dispatch.
# DRIFTPET_CLAUDE_BIN=claude
# DRIFTPET_CLAUDE_CODE_BIN=claude
# DRIFTPET_YT_DLP_BIN=yt-dlp

# LLM provider selection:
# anthropic | openai | openai-compatible
DRIFTPET_LLM_PROVIDER=anthropic

# Shared override for any provider key
# DRIFTPET_LLM_API_KEY=

# Provider-specific keys
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Optional provider-specific base URL override.
# Required for openai-compatible if DRIFTPET_LLM_ENDPOINT is not set.
# DRIFTPET_LLM_BASE_URL=

# Optional full endpoint override.
# Examples:
# - Anthropic: https://api.anthropic.com/v1/messages
# - OpenAI Responses: https://api.openai.com/v1/responses
# - DeepSeek/OpenAI-compatible: https://api.deepseek.com/v1/chat/completions
# DRIFTPET_LLM_ENDPOINT=

# Model selection
DRIFTPET_DIGEST_MODEL=claude-sonnet-4-20250514
DRIFTPET_REMARK_MODEL=claude-sonnet-4-20250514

# Embedding recall config.
# Provider options:
# openai | openai-compatible | ollama | disabled
# If omitted, driftpet derives this from DRIFTPET_LLM_PROVIDER.
# For split setups, prefer DRIFTPET_EMBED_API_KEY over OPENAI_API_KEY so text and embeddings stay isolated.
# DRIFTPET_EMBED_PROVIDER=
# DRIFTPET_EMBED_API_KEY=
# DRIFTPET_EMBED_BASE_URL=
# DRIFTPET_EMBED_ENDPOINT=
# DRIFTPET_EMBED_MODEL=text-embedding-3-small

# Example provider blocks
#
# Anthropic text + OpenAI embeddings
# DRIFTPET_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# DRIFTPET_DIGEST_MODEL=claude-sonnet-4-20250514
# DRIFTPET_REMARK_MODEL=claude-sonnet-4-20250514
# DRIFTPET_EMBED_PROVIDER=openai
# DRIFTPET_EMBED_API_KEY=
# DRIFTPET_EMBED_MODEL=text-embedding-3-small
#
# OpenAI / Codex path
# DRIFTPET_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# DRIFTPET_DIGEST_MODEL=gpt-5-mini
# DRIFTPET_REMARK_MODEL=gpt-5-mini
# DRIFTPET_EMBED_PROVIDER=openai
# DRIFTPET_EMBED_MODEL=text-embedding-3-small
#
# Relay for text + OpenAI embeddings
# DRIFTPET_LLM_PROVIDER=openai
# DRIFTPET_LLM_API_KEY=
# DRIFTPET_LLM_ENDPOINT=https://your-relay.example/v1/responses
# DRIFTPET_DIGEST_MODEL=gpt-5.5
# DRIFTPET_REMARK_MODEL=gpt-5.5
# DRIFTPET_EMBED_PROVIDER=openai
# DRIFTPET_EMBED_API_KEY=
# DRIFTPET_EMBED_MODEL=text-embedding-3-small
#
# Relay for text + local Ollama embeddings
# DRIFTPET_LLM_PROVIDER=openai
# DRIFTPET_LLM_API_KEY=
# DRIFTPET_LLM_ENDPOINT=https://your-relay.example/v1/responses
# DRIFTPET_DIGEST_MODEL=gpt-5.5
# DRIFTPET_REMARK_MODEL=gpt-5.5
# DRIFTPET_EMBED_PROVIDER=ollama
# DRIFTPET_EMBED_BASE_URL=http://127.0.0.1:11434
# DRIFTPET_EMBED_MODEL=qwen3-embedding:0.6b
#
# DeepSeek-compatible path
# DRIFTPET_LLM_PROVIDER=openai-compatible
# DEEPSEEK_API_KEY=
# DRIFTPET_LLM_BASE_URL=https://api.deepseek.com/v1
# DRIFTPET_DIGEST_MODEL=deepseek-chat
# DRIFTPET_REMARK_MODEL=deepseek-chat
# DRIFTPET_EMBED_PROVIDER=openai-compatible
# DRIFTPET_EMBED_BASE_URL=https://api.deepseek.com/v1
# DRIFTPET_EMBED_MODEL=text-embedding-3-small
