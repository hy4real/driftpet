{
  "name": "driftpet",
  "version": "0.1.0",
  "private": true,
  "description": "Mac 可爱桌面陪伴宠，顺手帮你收住碎片信息和小纸条。",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,main,electron -c cyan,yellow,green \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:dist-electron/electron/main.js && DRIFTPET_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "pack": "npm run build && electron-builder --mac",
    "pack:dir": "npm run build && electron-builder --mac --dir",
    "icon:generate": "node scripts/generate-icon.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "probe:chaos-recall": "node scripts/probe-manual-chaos-recall.mjs",
    "probe:chaos-recall-batch": "node scripts/probe-chaos-recall-batch.mjs",
    "probe:chaos-llm-batch": "node scripts/probe-chaos-llm-batch.mjs",
    "probe:telegram-mixed-batch": "node scripts/probe-telegram-mixed-batch.mjs",
    "probe:telegram-text-batch": "node scripts/probe-telegram-text-batch.mjs",
    "probe:url-llm-batch": "node scripts/probe-url-llm-batch.mjs",
    "test:telegram-parse": "node --test --experimental-strip-types scripts/parse-telegram-message.test.mjs",
    "test:telegram-note-workflow": "node --test scripts/telegram-note-workflow.test.mjs",
    "test:url-note-runner": "node --test --experimental-strip-types src/main/telegram/url-classifier.test.mjs src/main/telegram/url-note-runner-parse.test.mjs",
    "test:recall": "node --test --experimental-strip-types src/main/recall/scoring.test.mjs",
    "test:related": "npm run build:electron && node --test scripts/related-language-recall.test.mjs",
    "test:ingest-dedup": "npm run build:electron && node --test scripts/ingest-chaos-dedup.test.mjs",
    "test:ui-smoke": "node --test scripts/app-ui-smoke.test.mjs",
    "test:window-state": "node --test --experimental-strip-types src/main/app/window-state.test.mjs",
    "test:clipboard-watcher": "node --test --experimental-strip-types src/main/clipboard/watcher.test.mjs",
    "probe:url-fallback": "node scripts/probe-url-fallback-digest.mjs",
    "test:lore": "node --test scripts/validate-lore-commit.test.mjs",
    "test:workflow": "node --test scripts/workflow-fusion-bridge.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "validate:lore:commit": "node scripts/validate-lore-commit.mjs .git/COMMIT_EDITMSG",
    "workflow:sync": "node scripts/workflow-fusion-bridge.mjs sync",
    "workflow:refresh": "node scripts/workflow-fusion-bridge.mjs refresh",
    "workflow:status": "node scripts/workflow-fusion-bridge.mjs status",
    "workflow:check": "node scripts/workflow-fusion-bridge.mjs check",
    "workflow:guard:dispatch": "node workflow-fusion/scripts/response-guard.mjs --kind dispatch --file .workflow/runtime/reports/driftpet-overnight-loop-dispatch.md",
    "workflow:guard:report": "node workflow-fusion/scripts/response-guard.mjs --kind report --file .workflow/runtime/reports/driftpet-overnight-loop-latest.md"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "jsdom": "^27.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.9.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  }
}
